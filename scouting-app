<script>
const calIcon = '<svg viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="11" rx="1.5" stroke="#8A8A8A"/><path d="M5 1.5v3M11 1.5v3M2 7h12" stroke="#8A8A8A" stroke-linecap="round"/></svg>';
