const addIcon = '<svg viewBox="0 0 16 16" fill="none"><path d="M8 3v10M3 8h10" stroke="#243657" stroke-width="2" stroke-linecap="round"/></svg>';
const chevIcon = '<svg viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="#8A8A8A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

/* Named player images — exact locked mapping */
const playerImgs = {
  'James_Whitfield':  'data:image/jpeg;base64,',
  'Oliver_Hartley':   'data:image/jpeg;base64,',
  'Paulina_Callum':   'data:image/jpeg;base64,',
  'Marcus_Reed':      'data:image/jpeg;base64,',
  'Ben_Holloway':     'data:image/jpeg;base64,',
  'Callum_Price':     'data:image/jpeg;base64,',
  'Conor_Walsh':      'data:image/jpeg;base64,',
  'Toby_Mason':       'data:image/jpeg;base64,',
};

/* Playing next — locked order: James, Oliver, Paulina, Marcus */
const playingNext = [
  {name:'James Whitfield', age:21, role:'Pace bowler', date:'9 Jun 2026', venue:'The Oval',   img:'James_Whitfield'},
  {name:'Oliver Hartley',  age:19, role:'Opening bat',  date:'10 Jun 2026',venue:'Headingley',  img:'Oliver_Hartley'},
  {name:'Paulina Callum',  age:21, role:'Pace bowler', date:'9 Jun 2026', venue:'The Oval',   img:'Paulina_Callum'},
  {name:'Marcus Reed',     age:20, role:'Spin bowler', date:'11 Jun 2026',venue:"Lord's",      img:'Marcus_Reed'},
];

/* All players — locked order: Ben, Callum, Conor, James, Oliver, Toby */
const allPlayers = [
  {name:'Ben Holloway',   age:23, club:'Sussex',      role:'Pace bowler',  img:'Ben_Holloway'},
  {name:'Callum Price',   age:22, club:'Glamorgan',   role:'Spin bowler',  img:'Callum_Price'},
  {name:'Conor Walsh',    age:23, club:'Derbyshire',  role:'Pace bowler',  img:'Conor_Walsh'},
  {name:'James Whitfield',age:21, club:'Durham',      role:'Pace bowler',  img:'James_Whitfield'},
  {name:'Oliver Hartley', age:19, club:'Glamorgan',   role:'Opening bat',  img:'Oliver_Hartley'},
  {name:'Toby Mason',     age:24, club:'Kent',        role:'All-rounder',  img:'Toby_Mason'},
];

function renderNext(){
  document.getElementById('nextCarousel').innerHTML = playingNext.map(p=>`
    <div class="next-card">
      <div class="next-top">
        <div class="avatar" style="background-image:url('${playerImgs[p.img]}')"></div>
        <div>
          <div class="pname">${p.name}</div>
          <div class="pmeta">Age ${p.age}</div>
          <div class="prole">${p.role}</div>
        </div>
      </div>
      <div class="divider"></div>
      <div class="next-info">
        <div class="info-row">${calIcon}${p.date}</div>
        <div class="info-row">${pinIcon}${p.venue}</div>
      </div>
      <button class="report-btn" onclick="toast('Starting report for ${p.name}')">${addIcon}Report</button>
    </div>`).join('');
}

function renderList(players){
  document.getElementById('playerList').innerHTML = players.map(p=>`
    <div class="player-row" onclick="${p.name==='Ben Holloway'?'go(\'screen-8\')':'toast(\'Opening '+p.name+'\')'}">
      <div class="avatar round" style="background-image:url('${playerImgs[p.img]}')"></div>
      <div class="info">
        <div class="pname">${p.name}</div>
        <div class="pmeta" style="font-family:'Inter';font-size:13px">Age ${p.age} · ${p.club}</div>
        <div class="prole">${p.role}</div>
      </div>
      <div class="link" onclick="event.stopPropagation();${p.name==='Callum Price'?'go(\'screen-create-report-3\')':'toast(\'Starting report for '+p.name+'\')'}">+ Report ${chevIcon}</div>
    </div>`).join('');
}

var cr4SavedScroll = 0;
function go(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const sc = document.querySelector('#'+id+' .body, #'+id+' .notif-body, #'+id+' .ph-body, #'+id+' .cr3-body, #'+id+' .cr4-body');
  if(sc){
    if(id === 'screen-create-report-4'){
      /* restore saved scroll instead of jumping to top */
      sc.scrollTop = cr4SavedScroll;
    } else {
      sc.scrollTop = 0;
    }
  }
  if(id !== 'screen-create-report-4' && id !== 'screen-text-note' && id !== 'screen-voice') cr4Reset();
}

function openFilters(){ document.getElementById('overlay').classList.add('open'); }
function closeFilters(){ document.getElementById('overlay').classList.remove('open'); }

document.querySelectorAll('.chips .chip').forEach(chip=>{
  chip.addEventListener('click',()=>{ chip.classList.toggle('selected'); });
});

function countSelected(){
  return document.querySelectorAll('.chips .chip.selected').length;
}
function resetFilters(){
  document.querySelectorAll('.chips .chip.selected').forEach(c=>c.classList.remove('selected'));
}
function applyFilters(){
  const n = countSelected();
  document.getElementById('filtersLabel').textContent = n>0 ? `Filters (${n})` : 'Filters';
  closeFilters();
  if(n>0) toast(`${n} filter${n>1?'s':''} applied`);
}

function markAllRead(){
  document.querySelectorAll('#screen-notif .notif-card.unread').forEach(c=>c.classList.remove('unread'));
  document.querySelectorAll('#screen-notif .dot').forEach(d=>d.remove());
  const badge = document.querySelector('.bell-badge');
  if(badge) badge.style.display='none';
  toast('All notifications marked read');
}

let toastTimer;
function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'),1800);
}

document.getElementById('overlay').addEventListener('click',e=>{
  if(e.target.id==='overlay') closeFilters();
});

renderNext();
renderList(allPlayers);
</script>

