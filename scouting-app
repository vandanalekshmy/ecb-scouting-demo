<script>
function tnOpenNote(){
  /* remember where the report was scrolled to */
  var body = document.querySelector('#screen-create-report-4 .cr4-body');
  if(body) cr4SavedScroll = body.scrollTop;
  var textarea = document.querySelector('#screen-text-note .tn-textarea');
  if(textarea) textarea.value = '';
  go('screen-text-note');
  /* place the cursor in the input */
  if(textarea){
    setTimeout(function(){ textarea.focus(); }, 0);
  }
}
function tnSubmitNote(){
  go('screen-create-report-4');
  toast('Note added');
}

/* ---- Voice recording flow ---- */
var vrTimerInt = null, vrWaveInt = null, vrElapsed = 0;

function vrBuildWave(){
  var wave = document.getElementById('vrWave');
  if(!wave || wave.childElementCount) return;
  for(var i=0;i<48;i++){
    var bar = document.createElement('span');
    bar.className = 'vr-wave-bar';
    wave.appendChild(bar);
  }
}
function vrOpen(){
  /* remember report scroll so we can restore it */
  var body = document.querySelector('#screen-create-report-4 .cr4-body');
  if(body) cr4SavedScroll = body.scrollTop;
  /* always open in default (not recording) state */
  document.getElementById('screen-voice').classList.remove('recording');
  go('screen-voice');
}
function vrClose(){
  vrStopTicking();
  document.getElementById('screen-voice').classList.remove('recording');
  go('screen-create-report-4');
}
function vrStartRecording(){
  vrBuildWave();
  vrElapsed = 0;
  document.getElementById('vrTimer').textContent = '00:00.00';
  document.getElementById('screen-voice').classList.add('recording');
  /* timer: mm:ss.cs */
  var start = Date.now();
  vrTimerInt = setInterval(function(){
    vrElapsed = (Date.now() - start) / 1000;
    var m = Math.floor(vrElapsed/60);
    var s = Math.floor(vrElapsed%60);
    var cs = Math.floor((vrElapsed*100)%100);
    var pad = function(n){ return (n<10?'0':'')+n; };
    document.getElementById('vrTimer').textContent = pad(m)+':'+pad(s)+'.'+pad(cs);
  }, 40);
  /* animated waveform */
  var bars = document.querySelectorAll('#vrWave .vr-wave-bar');
  vrWaveInt = setInterval(function(){
    bars.forEach(function(bar){
      var h = 6 + Math.random()*Math.random()*42;
      bar.style.height = h.toFixed(0) + 'px';
    });
  }, 120);
}
function vrStopTicking(){
  if(vrTimerInt){ clearInterval(vrTimerInt); vrTimerInt = null; }
  if(vrWaveInt){ clearInterval(vrWaveInt); vrWaveInt = null; }
}
function vrStopRecording(){
  vrStopTicking();
  document.getElementById('screen-voice').classList.remove('recording');
  go('screen-create-report-4');
  toast('Voice note added');
}
</script>
