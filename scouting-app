<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>England Cricket — Scouting</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#000B1C;
    --ink:#1A2B47;
    --ink-2:#243657;
    --grey:#424242;
    --grey-mid:#8A8A8A;
    --line:#E5E5E5;
    --line-2:#E5E7EB;
    --bg:#F4F4F4;
    --white:#FFFFFF;
    --link:#1F5BD7;
    --badge:#D8294A;
    --blue-dot:#1AA8E0;
    --placeholder:#9CA3AF;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{
    font-family:'Plus Jakarta Sans',sans-serif;
    background:#0c0c10;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px;
    color:var(--ink);
  }
  .phone{
    position:relative;
    width:393px;
    height:852px;
    background:var(--bg);
    border-radius:42px;
    box-shadow:0 0 0 12px #1c1c22, 0 30px 80px rgba(0,0,0,.55);
    overflow:hidden;
  }
  .screen{
    position:absolute;
    inset:0;
    display:none;
    flex-direction:column;
    background:var(--bg);
  }
  .screen.active{display:flex;}

  /* ---------- Header ---------- */
  .header{
    background:radial-gradient(53.94% 185.38% at 100% 0%, rgba(0, 165, 252, 0.2) 24.74%, rgba(0, 16, 28, 0) 68.61%), radial-gradient(62.02% 405.42% at 0% 100%, #95040B 0%, #000B1C 17.25%);
    padding-bottom:20px;
    flex:0 0 auto;
    position:relative;
    z-index:5;
  }
  .header-bar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px;
    height:94px;
    background:transparent;
  }
  .logo{display:flex;align-items:center;}
  .logo img{height:40px;width:auto;display:block;}
  .bell-btn{
    position:relative;width:44px;height:44px;border:none;background:transparent;cursor:pointer;
    display:flex;align-items:center;justify-content:center;
  }
  .bell-btn svg{width:24px;height:24px;}
  .bell-badge{
    position:absolute;top:4px;right:5px;min-width:17px;height:16px;padding:0 3px;
    background:var(--badge);border:1px solid var(--ink);border-radius:9999px;
    font-family:'Inter';font-weight:700;font-size:10px;color:#fff;
    display:flex;align-items:center;justify-content:center;
  }
  .search-wrap{padding:0 20px;margin-top:8px;}
  .search{
    display:flex;align-items:center;gap:8px;
    background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);
    border-radius:12px;padding:10px 16px;
  }
  .search svg{width:20px;height:20px;flex:0 0 auto;}
  .search input{
    background:transparent;border:none;outline:none;color:#fff;
    font-family:'Inter';font-size:14px;width:100%;
  }
  .search input::placeholder{color:var(--placeholder);}
  .controls{
    display:flex;justify-content:space-between;align-items:center;
    padding:0 20px;margin-top:14px;
  }
  .filters-btn{
    display:flex;align-items:center;gap:7px;background:none;border:none;cursor:pointer;
    color:#fff;font-family:'Inter';font-weight:500;font-size:14px;
  }
  .filters-btn svg{width:16px;height:16px;}
  .sort{display:flex;align-items:center;gap:6px;}
  .sort-label{font-size:12px;color:rgba(255,255,255,.6);}
  .sort-btn{
    display:flex;align-items:center;gap:14px;
    background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);
    border-radius:8px;padding:6px 8px;color:#fff;font-size:12px;cursor:pointer;
  }
  .sort-btn svg{width:14px;height:14px;}

  /* ---------- Main scroll body ---------- */
  .body{flex:1 1 auto;overflow-y:auto;padding:20px;-webkit-overflow-scrolling:touch;}
  .body::-webkit-scrollbar{width:0;}
  .eyebrow{
    font-weight:500;font-size:12px;letter-spacing:1.2px;color:var(--grey);
    text-transform:uppercase;margin-bottom:12px;
  }

  /* Playing-next horizontal carousel */
  .carousel{
    display:flex;gap:10px;overflow-x:auto;padding-bottom:4px;margin-bottom:24px;
    scroll-snap-type:x mandatory;
  }
  .carousel::-webkit-scrollbar{height:0;}
  .next-card{
    flex:0 0 270px;scroll-snap-align:start;
    background:#fff;border:1px solid var(--line);border-radius:12px;
    box-shadow:0 1px 2px rgba(26,43,71,.08);padding:16px;
  }
  .next-top{display:flex;gap:12px;align-items:center;}

  /* Avatar — 63×68 circular */
  .avatar{
    width:63px;
    height:68px;
    flex:0 0 63px;
    border-radius:9999px;
    background:#c9d3df;
    background-size:cover;
    background-position:top center;
    overflow:hidden;
  }
  .avatar.round{
    width:63px;
    height:68px;
    border-radius:9999px;
    background-size:cover;
    background-position:top center;
  }

  .pname{font-weight:600;font-size:14px;color:var(--ink);}
  .pmeta{font-size:12px;color:var(--grey);margin-top:2px;}
  .prole{font-size:14px;color:var(--ink);margin-top:6px;}
  .divider{border-top:1px solid var(--line);margin:12px 0;}
  .next-info{display:flex;flex-direction:column;gap:8px;}
  .info-row{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--grey);}
  .info-row svg{width:16px;height:16px;flex:0 0 auto;}
  .report-btn{
    width:100%;margin-top:12px;display:flex;align-items:center;justify-content:center;gap:6px;
    border:1px solid #000;border-radius:8px;padding:6px 32px;background:#fff;cursor:pointer;
    color:var(--ink-2);font-weight:500;font-size:14px;font-family:inherit;
  }
  .report-btn svg{width:16px;height:16px;}

  /* All-players list */
  .player-row{
    background:#fff;border:1px solid var(--line);border-radius:12px;padding:16px;
    display:flex;align-items:center;gap:10px;margin-bottom:10px;cursor:pointer;
  }
  .player-row .info{flex:1 1 auto;}
  .player-row .link{
    display:flex;align-items:center;gap:8px;color:var(--link);
    font-weight:500;font-size:16px;white-space:nowrap;
  }
  .player-row .link svg{width:16px;height:16px;}

  /* ---------- Bottom nav ---------- */
  .bottom-nav{
    flex:0 0 auto;height:81px;background:#fff;border-top:1px solid var(--line);
    display:flex;align-items:flex-start;justify-content:space-around;padding-top:9px;
  }
  .nav-item{
    display:flex;flex-direction:column;align-items:center;gap:6px;
    background:none;border:none;cursor:pointer;color:var(--grey-mid);
    font-family:'Inter';font-weight:500;font-size:11px;width:80px;padding-top:2px;
  }
  .nav-item svg{width:24px;height:24px;}
  .nav-item.active{color:var(--ink);}

  /* ---------- Filter modal ---------- */
  .overlay{
    position:absolute;inset:0;background:rgba(0,0,0,.6);z-index:40;
    display:none;
  }
  .overlay.open{display:block;}
  .sheet{
    position:absolute;left:0;right:0;bottom:0;top:167px;
    background:#fff;border-radius:24px 24px 0 0;
    display:flex;flex-direction:column;
    transform:translateY(100%);transition:transform .32s cubic-bezier(.22,1,.36,1);
  }
  .overlay.open .sheet{transform:translateY(0);}
  .sheet-head{padding:20px;border-bottom:1px solid var(--line);}
  .grabber{width:48px;height:6px;background:var(--line);border-radius:9999px;margin:0 auto 14px;}
  .sheet-title-row{display:flex;justify-content:space-between;align-items:center;}
  .sheet-title{font-weight:600;font-size:18px;color:var(--ink);}
  .close-btn{width:36px;height:36px;border:none;background:none;cursor:pointer;border-radius:9999px;display:flex;align-items:center;justify-content:center;}
  .close-btn svg{width:20px;height:20px;}
  .sheet-body{flex:1 1 auto;overflow-y:auto;padding:20px;}
  .sheet-body::-webkit-scrollbar{width:0;}
  .filter-group{margin-bottom:28px;}
  .filter-group h3{font-weight:600;font-size:16px;color:var(--ink);margin-bottom:12px;}
  .chips{display:flex;flex-wrap:wrap;gap:8px;}
  .chip{
    display:inline-flex;align-items:center;gap:6px;
    border:1px solid var(--line);background:#fff;border-radius:9999px;
    padding:8px 16px;font-family:'Inter';font-weight:500;font-size:14px;color:var(--grey);
    cursor:pointer;transition:background .12s,color .12s,border-color .12s;
  }
  .chip .tick{width:14px;height:14px;display:none;}
  .chip.selected{background:var(--ink);border-color:var(--ink);color:#fff;}
  .chip.selected .tick{display:inline-block;}
  .sheet-foot{
    flex:0 0 auto;padding:20px;border-top:1px solid var(--line);
    display:flex;gap:12px;
  }
  .btn-reset,.btn-apply{
    flex:1;border-radius:8px;padding:8px;font-family:inherit;font-weight:500;font-size:16px;cursor:pointer;
  }
  .btn-reset{background:#fff;border:1px solid var(--ink);color:var(--ink);}
  .btn-apply{background:var(--ink);border:1px solid var(--ink);color:#fff;}

  /* ---------- Notifications ---------- */
  .notif-head{
    background:var(--navy);height:68px;display:flex;align-items:center;
    justify-content:space-between;padding:12px 8px;flex:0 0 auto;
  }
  .icon-btn{width:44px;height:44px;border:none;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .icon-btn svg{width:24px;height:24px;}
  .mark-read{color:#fff;font-family:'Inter';font-weight:500;font-size:14px;background:none;border:none;cursor:pointer;padding:12px;}
  .notif-body{flex:1 1 auto;overflow-y:auto;padding:20px;}
  .notif-body::-webkit-scrollbar{width:0;}
  .notif-section{margin-bottom:24px;}
  .notif-section > .eyebrow{margin-bottom:12px;}
  .notif-card{
    display:flex;gap:12px;align-items:flex-start;padding:17px;
    border:1px solid var(--line-2);border-radius:12px;margin-bottom:12px;background:#fff;
  }
  .notif-card.unread{background:#F4F8FC;}
  .notif-ic{
    width:36px;height:36px;border-radius:9999px;background:var(--bg);
    flex:0 0 auto;display:flex;align-items:center;justify-content:center;
  }
  .notif-ic svg{width:20px;height:20px;}
  .notif-content{flex:1 1 auto;}
  .notif-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
  .notif-title{font-weight:600;font-size:14px;color:var(--ink);}
  .notif-right{display:flex;align-items:center;gap:8px;flex:0 0 auto;}
  .notif-time{font-family:'Inter';font-size:11px;color:var(--grey-mid);white-space:nowrap;}
  .dot{width:10px;height:10px;border-radius:9999px;background:var(--blue-dot);}
  .notif-text{font-size:14px;color:var(--grey);line-height:20px;margin-top:2px;}

  .toast{
    position:absolute;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);
    background:var(--ink);color:#fff;font-size:13px;font-weight:500;
    padding:10px 18px;border-radius:9999px;opacity:0;pointer-events:none;
    transition:opacity .25s,transform .25s;z-index:60;white-space:nowrap;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
<div class="phone" id="phone">

  <!-- ============ SCREEN 1 : PLAYERS HOME ============ -->
  <section class="screen active" id="screen-home">
    <div class="header">
      <div class="header-bar">
        <div class="logo">
          <img src="data:image/png;base64," alt="England Cricket" />
        </div>
        <button class="bell-btn" onclick="go('screen-notif')" aria-label="Notifications">
          <svg viewBox="0 0 24 24" fill="none"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.7 21a2 2 0 0 1-3.4 0" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="bell-badge">3</span>
        </button>
      </div>
      <div class="search-wrap">
        <div class="search">
          <svg viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="6.5" stroke="rgba(255,255,255,.5)" stroke-width="2"/><path d="M14 14l4 4" stroke="rgba(255,255,255,.5)" stroke-width="2" stroke-linecap="round"/></svg>
          <input placeholder="Search name, county, role…">
        </div>
      </div>
      <div class="controls">
        <button class="filters-btn" onclick="openFilters()">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M14 2.66992H9.32999" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.67 2.66992H2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 8H8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.33 8H2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 13.3301H10.67" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 13.3301H2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.32999 1.33008V4.00008" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.32999 6.66992V9.33992" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M10.67 12V14.67" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span id="filtersLabel">Filters</span>
        </button>
        <div class="sort">
          <span class="sort-label">Sort:</span>
          <button class="sort-btn">Alphabetical
            <svg viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="#F4F4F4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="body">
      <div class="eyebrow">Playing next</div>
      <div class="carousel" id="nextCarousel"></div>
      <div class="eyebrow">All players</div>
      <div id="playerList"></div>
    </div>

    <nav class="bottom-nav">
      <button class="nav-item active">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M16 21V19C16 16.7909 14.2091 15 12 15H6C3.79086 15 2 16.7909 2 19V21" stroke="#1A2B47" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 7C5 4.79086 6.79086 3 9 3C11.2091 3 13 4.79086 13 7C13 9.20914 11.2091 11 9 11C6.79086 11 5 9.20914 5 7Z" stroke="#1A2B47" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 20.9999V18.9999C21.9986 17.177 20.765 15.5856 19 15.1299" stroke="#1A2B47" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 3.12988C17.7712 3.58305 19.01 5.17787 19.01 7.00488C19.01 8.83189 17.7712 10.4267 16 10.8799" stroke="#1A2B47" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Players
      </button>
      <button class="nav-item" onclick="go('screen-12')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V7L15 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2V6C14 7.10457 14.8954 8 16 8H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 9H8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 13H8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 17H8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Reports
      </button>
      <button class="nav-item" onclick="toast('Account coming soon')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M19 21V19C19 16.7909 17.2091 15 15 15H9C6.79086 15 5 16.7909 5 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7C16 9.20914 14.2091 11 12 11C9.79086 11 8 9.20914 8 7Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Account
      </button>
    </nav>

    <!-- Filter modal -->
    <div class="overlay" id="overlay">
      <div class="sheet">
        <div class="sheet-head">
          <div class="grabber"></div>
          <div class="sheet-title-row">
            <span class="sheet-title">Filters</span>
            <button class="close-btn" onclick="closeFilters()" aria-label="Close">
              <svg viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="#424242" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
          </div>
        </div>
        <div class="sheet-body">
          <div class="filter-group">
            <h3>Position</h3>
            <div class="chips">
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Batter</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Pace bowler</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Spin bowler</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>All-rounder</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Wicket keeper</button>
            </div>
          </div>
          <div class="filter-group">
            <h3>Age range</h3>
            <div class="chips">
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>U20</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>20-22</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>23-25</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>26+</button>
            </div>
          </div>
          <div class="filter-group">
            <h3>Club</h3>
            <div class="chips">
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Durham</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Glamorgan</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Sussex</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Kent</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Surrey</button>
            </div>
          </div>
          <div class="filter-group">
            <h3>Region</h3>
            <div class="chips">
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>North</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Midlands</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>South</button>
              <button class="chip"><svg class="tick" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Wales</button>
            </div>
          </div>
        </div>
        <div class="sheet-foot">
          <button class="btn-reset" onclick="resetFilters()">Reset</button>
          <button class="btn-apply" onclick="applyFilters()">Apply filters</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SCREEN 2 : NOTIFICATIONS ============ -->
  <section class="screen" id="screen-notif">
