<script>
/* CR4: populate avatar */
(function(){
  var img = document.getElementById('cr4-avatar-img');
  if(img && typeof playerImgs !== 'undefined' && playerImgs['Callum_Price']){
    img.src = playerImgs['Callum_Price'];
  }
})();
/* CR4: FAB toggle */
function cr4ToggleFab(){
  var menu = document.getElementById('cr4FabMenu');
  var btn  = document.getElementById('cr4FabMain');
  var plus  = btn.querySelector('.cr4-fab-plus');
  var close = btn.querySelector('.cr4-fab-close');
  var isOpen = menu.classList.toggle('open');
  btn.classList.toggle('open', isOpen);
  plus.style.display  = isOpen ? 'none'  : 'block';
  close.style.display = isOpen ? 'block' : 'none';
}
/* CR4: expand / collapse a section */
function cr4ToggleSection(id){
  var sec = document.getElementById(id);
  if(sec) sec.classList.toggle('cr4-section--open');
}
/* CR4: submit report → success screen (only when enabled) */
function cr4SubmitReport(btn){
  if(!btn.classList.contains('enabled')) return;
  go('screen-success');
}
/* CR4: enable submit when any rating/option is selected */
function cr4UpdateBattingProgress(){
  var section = document.getElementById('cr4Section-batting');
  var total = 10; // 8 scale questions + 2 opt questions
  var answered = section.querySelectorAll('.cr4-val.selected, .cr4-opt.selected').length;
  // Count unique answered questions (one answer per question)
  var answeredQs = 0;
  section.querySelectorAll('.cr4-q').forEach(function(q){
    if(q.querySelector('.cr4-val.selected, .cr4-opt.selected')) answeredQs++;
  });
  var badge = document.getElementById('cr4-batting-progress');
  if(!badge) return;
  var text = badge.querySelector('.cr4-progress-text');
  var dot = badge.querySelector('.cr4-progress-dot');
  text.textContent = answeredQs + ' of ' + total;
  dot.className = 'cr4-progress-dot';
  if(answeredQs === 0){
    dot.classList.add('cr4-progress-dot--red');
  } else if(answeredQs === total){
    dot.classList.add('cr4-progress-dot--green');
  } else {
    dot.classList.add('cr4-progress-dot--orange');
  }
}
function cr4UpdateSubmit(){
  var anySelected = !!document.querySelector('#screen-create-report-4 .cr4-val.selected, #screen-create-report-4 .cr4-opt.selected, #screen-create-report-4 .cr4-chip.selected');
  document.querySelector('#screen-create-report-4 .cr4-submit-btn').classList.toggle('enabled', anySelected);
}
/* CR4: value scale single-select within a question, with toggle-off + caption */
var cr4ValCaptions = {
  '-2': 'Significantly below peers',
  '-1': 'Somewhat below peers',
  '=':  'Equal to peers',
  '+1': 'Good relative to peers',
  '+2': 'Outstanding relative to peers'
};
function cr4SelectVal(btn){
  var q = btn.closest('.cr4-q');
  var scale = btn.closest('.cr4-q-scale');
  var caption = q.querySelector('.cr4-q-caption');
  var wasSelected = btn.classList.contains('selected');
  scale.querySelectorAll('.cr4-val').forEach(function(b){ b.classList.remove('selected'); });
  if(wasSelected){
    if(caption){ caption.textContent = 'No rating'; caption.classList.remove('has-rating'); }
  } else {
    btn.classList.add('selected');
    var key = btn.textContent.trim();
    if(caption){ caption.textContent = cr4ValCaptions[key] || 'No rating'; caption.classList.add('has-rating'); }
  }
  cr4UpdateSubmit();
  cr4UpdateBattingProgress();
}
/* CR4: multi-option single-select within a question */
function cr4SelectOpt(btn){
  var grp = btn.closest('.cr4-q-opts');
  grp.querySelectorAll('.cr4-opt').forEach(function(b){ b.classList.remove('selected'); });
  btn.classList.add('selected');
  cr4UpdateSubmit();
  cr4UpdateBattingProgress();
}
/* CR4: single-select chip, deselectable + submit state */
function cr4SelectChip(chip){
  var wasSelected = chip.classList.contains('selected');
  document.querySelectorAll('#screen-create-report-4 .cr4-chip').forEach(function(c){
    c.classList.remove('selected');
  });
  if(!wasSelected) chip.classList.add('selected');
  var anySelected = !!document.querySelector('#screen-create-report-4 .cr4-chip.selected');
  document.querySelector('#screen-create-report-4 .cr4-submit-btn').classList.toggle('enabled', anySelected);
}
function cr4Reset(){
  cr4SavedScroll = 0;
  document.querySelectorAll('#screen-create-report-4 .cr4-chip').forEach(function(c){
    c.classList.remove('selected');
  });
  /* clear rating + option selections, restore captions */
  document.querySelectorAll('#screen-create-report-4 .cr4-val, #screen-create-report-4 .cr4-opt').forEach(function(b){
    b.classList.remove('selected');
  });
  document.querySelectorAll('#screen-create-report-4 .cr4-q-caption').forEach(function(c){
    c.textContent = 'No rating';
    c.classList.remove('has-rating');
  });
  document.querySelector('#screen-create-report-4 .cr4-submit-btn').classList.remove('enabled');
  cr4UpdateBattingProgress();
  document.querySelectorAll('#screen-create-report-4 .cr4-range').forEach(function(input){
    input.value = 0;
    var row = input.closest('.cr4-skill-row');
    row.querySelector('.cr4-skill-fill').style.width = '0%';
    row.querySelector('.cr4-skill-value').textContent = '0';
  });
  /* restore empty notes state */
  var empty = document.getElementById('cr4NotesEmpty');
  var scout = document.getElementById('cr4ScoutNotes');
  if(empty) empty.style.display = '';
  if(scout) scout.style.display = 'none';
}
/* CR4: skill slider update */
function cr4UpdateSkill(input){
  var row   = input.closest('.cr4-skill-row');
  var fill  = row.querySelector('.cr4-skill-fill');
  var value = row.querySelector('.cr4-skill-value');
  var v = parseInt(input.value, 10);
  value.textContent = v;
  /* fill width = thumb-centre position at value v
     thumb is 20px wide; track width = input.offsetWidth
     centre of thumb at v = (v/10) * (trackWidth - thumbWidth) + thumbWidth/2  */
  var thumbW = 20;
  var trackW = input.offsetWidth;
  var pct = (v / 10) * (trackW - thumbW) + thumbW / 2;
  fill.style.width = pct + 'px';
}
</script>
